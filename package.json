{
  "name": "hhauto",
  "version": "7.35.46",
  "description": "[English](https://github.com/OldRon1977/HHauto/wiki/English)",
  "main": "HHAuto.user.js",
  "scripts": {
    "test": "jest",
    "build": "webpack --config webpack.config.js",
    "lint": "eslint \"src/**/*.ts\" \"spec/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json",
    "deps:graph": "madge --extensions ts src",
    "deps:circular": "madge --circular --extensions ts src",
    "deps:circular:check": "node scripts/check-circular-deps.mjs",
    "deps:dead": "knip",
    "deps:unused": "depcheck --ignores=\"karma*,@babel/*,babel-jest,ts-jest,ts-node\"",
    "dup:check": "jscpd src --min-lines 10 --min-tokens 70 --reporters console,html --output ./coverage/jscpd",
    "bundle:stats": "webpack --config webpack.config.js --profile --json > stats.json",
    "bundle:analyze": "webpack-bundle-analyzer stats.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OldRon1977/HHauto.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/OldRon1977/HHauto/issues"
  },
  "homepage": "https://github.com/OldRon1977/HHauto#readme",
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-typescript": "^7.23.3",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/jquery": "^3.5.29",
    "@types/tampermonkey": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-jest": "^29.7.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jquery": "^3.7.1",
    "jscpd": "^4.1.1",
    "karma": "^6.4.2",
    "karma-browserify": "^8.1.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-commonjs": "^1.0.0",
    "karma-jasmine": "^5.1.0",
    "knip": "^6.13.1",
    "madge": "^8.0.0",
    "mock-local-storage": "^1.1.24",
    "terser-webpack-plugin": "^5.3.9",
    "ts-jest": "^29.1.1",
    "ts-morph": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "source-map-loader": "^4.0.1",
    "ts-loader": "^9.5.1"
  }
}
